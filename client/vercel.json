{
  "rewrites": [
    {
      "source": "/property/:path*",
      "destination": "https://dream-house-server-coral.vercel.app/property/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://dream-house-server-coral.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

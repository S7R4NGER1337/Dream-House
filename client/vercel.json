{
  "rewrites": [
    {
      "source": "/property/:path*",
      "destination": "https://REPLACE_WITH_SERVER_VERCEL_URL/property/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_SERVER_VERCEL_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
